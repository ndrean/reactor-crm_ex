# Database
POSTGRES_USER=postgres_admin
POSTGRES_PASSWORD=please-change-me
POSTGRES_DB=crm_reactor_prod
DATABASE_URL=ecto://postgres_admin:please-change-me@postgres:5432/crm_reactor_prod

# Phoenix
SECRET_KEY_BASE=generate-with-mix-phx-gen-secret
PHX_HOST=localhost
PORT=4000

# AI
MISTRAL_API_KEY=CRTkj3hF2RKr8shlai9VQNU9fSYnuLRW
# Primary classifier (default: mistral-small-latest ~€0.15/€0.60 per M tokens)
MISTRAL_MODEL_SMALL=mistral-small-latest
# Escalation when small returns 'none' (default: mistral-medium-latest ~€1.5/€7.5 per M tokens)
MISTRAL_MODEL_LARGE=mistral-medium-latest
# Vision/OCR model for file attachments (default: ministral-3-3b-2512 ~€0.10/€0.10 per M tokens)
MISTRAL_VISION_MODEL=ministral-3b-2512
WHISPER_URL=http://whisper:8000
# OLLAMA_URL=http://host.docker.internal:11435
OLLAMA_URL=http://127.0.0.1:11435

OLLAMA_MODEL=qwen2.5:7b

# File storage
# Local filesystem path (dev). Set STORAGE_BACKEND=b2 in prod and configure B2 credentials.
STORAGE_PATH=priv/uploads

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_SECRET_TOKEN=

# Encryption (generate with: elixir -e 'IO.puts(Base.encode64(:crypto.strong_rand_bytes(32)))')
CLOAK_KEY=generate-a-32-byte-base64-key

# Admin
ADMIN_TOKEN=change-me-in-prod

# Grafana
GF_SECURITY_ADMIN_PASSWORD=admin
