{
  "uid": "crm-phoenix",
  "title": "CRM Reactor - Phoenix",
  "tags": ["crm-reactor"],
  "timezone": "browser",
  "editable": true,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "title": "Request Duration (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 0 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.5, rate(crm_reactor_prom_ex_phoenix_http_request_duration_milliseconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(crm_reactor_prom_ex_phoenix_http_request_duration_milliseconds_bucket[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(crm_reactor_prom_ex_phoenix_http_request_duration_milliseconds_bucket[5m]))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        { "expr": "rate(crm_reactor_prom_ex_phoenix_http_request_duration_milliseconds_count[5m])", "legendFormat": "Req/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Response Status Codes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (status) (rate(crm_reactor_prom_ex_phoenix_http_request_duration_milliseconds_count[5m]))", "legendFormat": "{{ status }}" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } } }
    },
    {
      "title": "LiveView Mount Duration (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(crm_reactor_prom_ex_phoenix_live_view_mount_duration_milliseconds_bucket[5m]))", "legendFormat": "Mount p95" },
        { "expr": "histogram_quantile(0.95, rate(crm_reactor_prom_ex_phoenix_live_view_handle_event_duration_milliseconds_bucket[5m]))", "legendFormat": "Event p95" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "schemaVersion": 39
}
