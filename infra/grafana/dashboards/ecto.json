{
  "uid": "crm-ecto",
  "title": "CRM Reactor - Ecto",
  "tags": ["crm-reactor"],
  "timezone": "browser",
  "editable": true,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "title": "Query Duration (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 0 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.5, rate(crm_reactor_prom_ex_ecto_repo_query_duration_milliseconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(crm_reactor_prom_ex_ecto_repo_query_duration_milliseconds_bucket[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(crm_reactor_prom_ex_ecto_repo_query_duration_milliseconds_bucket[5m]))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "title": "Query Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        { "expr": "rate(crm_reactor_prom_ex_ecto_repo_query_duration_milliseconds_count[5m])", "legendFormat": "Queries/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Queue Time (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(crm_reactor_prom_ex_ecto_repo_query_queue_duration_milliseconds_bucket[5m]))", "legendFormat": "Queue p95" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "title": "Idle Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        { "expr": "crm_reactor_prom_ex_ecto_repo_query_idle_duration_milliseconds_count", "legendFormat": "Idle count" }
      ]
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "schemaVersion": 39
}
