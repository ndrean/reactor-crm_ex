{
  "uid": "crm-application",
  "title": "CRM Reactor - Application",
  "tags": ["crm-reactor"],
  "timezone": "browser",
  "editable": true,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        { "expr": "crm_reactor_prom_ex_application_uptime_milliseconds_count", "legendFormat": "Uptime" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "title": "App Info",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        { "expr": "crm_reactor_prom_ex_application_primary_info", "legendFormat": "v{{ version }} ({{ modules }} modules)" }
      ],
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "1": { "text": "Running" } } }] } }
    },
    {
      "title": "Dependencies",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        { "expr": "crm_reactor_prom_ex_application_dependency_info", "format": "table", "instant": true }
      ],
      "transformations": [
        { "id": "filterFieldsByName", "options": { "include": { "names": ["name", "version"] } } }
      ]
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "schemaVersion": 39
}
