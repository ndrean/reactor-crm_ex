{
  "uid": "crm-oban",
  "title": "CRM Reactor - Oban",
  "tags": ["crm-reactor"],
  "timezone": "browser",
  "editable": true,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "title": "Job Execution Duration (p50 / p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.5, rate(crm_reactor_prom_ex_oban_job_duration_milliseconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(crm_reactor_prom_ex_oban_job_duration_milliseconds_bucket[5m]))", "legendFormat": "p95" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "title": "Jobs by State",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (worker) (rate(crm_reactor_prom_ex_oban_job_duration_milliseconds_count[5m]))", "legendFormat": "{{ worker }}" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 15 } } }
    },
    {
      "title": "Job Exceptions (1h)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        { "expr": "sum(increase(crm_reactor_prom_ex_oban_job_exception_duration_milliseconds_count[1h]))", "legendFormat": "Exceptions" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 1, "color": "orange" },
              { "value": 10, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "title": "Queue Wait Time (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(crm_reactor_prom_ex_oban_job_queue_time_milliseconds_bucket[5m]))", "legendFormat": "Queue Wait p95" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "schemaVersion": 39
}
