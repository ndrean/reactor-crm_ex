{
  "uid": "crm-beam",
  "title": "CRM Reactor - BEAM",
  "tags": ["crm-reactor"],
  "timezone": "browser",
  "editable": true,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        { "expr": "crm_reactor_prom_ex_beam_memory_allocated_bytes", "legendFormat": "Total" },
        { "expr": "crm_reactor_prom_ex_beam_memory_processes_total_bytes", "legendFormat": "Processes" },
        { "expr": "crm_reactor_prom_ex_beam_memory_ets_total_bytes", "legendFormat": "ETS" },
        { "expr": "crm_reactor_prom_ex_beam_memory_binary_total_bytes", "legendFormat": "Binary" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10 } } }
    },
    {
      "title": "Process Count",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        { "expr": "crm_reactor_prom_ex_beam_stats_process_count", "legendFormat": "Processes" }
      ]
    },
    {
      "title": "Run Queue Length",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        { "expr": "crm_reactor_prom_ex_beam_stats_run_queue_length", "legendFormat": "Run Queue" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 10, "color": "yellow" },
              { "value": 50, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "title": "GC Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        { "expr": "rate(crm_reactor_prom_ex_beam_stats_gc_count[5m])", "legendFormat": "GC/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "GC Reclaimed",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        { "expr": "rate(crm_reactor_prom_ex_beam_stats_gc_reclaimed_bytes[5m])", "legendFormat": "Reclaimed/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "schemaVersion": 39
}
